NODE_ENV=development
PORT=3000
APP_NAME=SFMS API
API_PREFIX=/api
API_VERSION=1

# Comma-separated list. Leave empty to allow all origins (dev only).
CORS_ORIGINS=http://localhost:5173

SWAGGER_ENABLED=true
SWAGGER_PATH=/docs

MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=SFMS Care Team
MAIL_FROM_ADDRESS=

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

DB_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=sfms
DB_SSL=false
DB_LOGGING=false
DB_SYNCHRONIZE=true

JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL_SECONDS=604800

SEED_ENABLED=true
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=Super Admin

# Cloudflare R2 (S3-compatible storage) for Images
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
